#include <bits/stdc++.h>
using namespace std;
class Graph{
public:
  int v;
  list<int>*l;
  Graph(int v){
      this->v = v;
      l = new list<int>[v];
  }
  void add(int u,int v){
      l[u].push_back(v);
      l[v].push_back(u);
  }
  void print(){   //bi directional graph
      for(int i =0;i<v;i++){
          cout<<i<<"->";
          for(int val:l[i]){
              cout<<val<<"  ";
          }
          cout<<endl;
      }
      cout<<"printing finished"<<endl;
  }
  void BFS(){
      queue<int>q;
      vector<bool>V(v,false);
      q.push(0);
      V[0] = true;
      while(!q.empty()){
          int node = q.front();
          cout<<node<<" ";
          q.pop();
          for(int val:l[node]){
              if(!V[val]){
                  V[val] = true;
                  q.push(val);
              }
              
          }
      }
      
  }
  void DfsHelper(int u,vector<bool>&vis){
      cout<<u<<" ";
      vis[u] = true;
      for(int val:l[u]){
          if(!vis[val]){
              DfsHelper(val,vis);
          }
      }
  }
  
  void DFS(){
      int src =0;
      vector<bool>vis(v,false);
      DfsHelper(src,vis);
  }
};
int main() {
